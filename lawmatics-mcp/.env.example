# Lawmatics MCP — environment configuration
# The MCP server reads these (or ~/.config/lawmatics-mcp/config.json).

# REQUIRED to run the server: a firm's non-expiring Lawmatics bearer token.
LAWMATICS_ACCESS_TOKEN=

# Optional: override the API base (defaults to https://api.lawmatics.com).
# LAWMATICS_BASE_URL=https://api.lawmatics.com

# Only needed to run `lawmatics-mcp auth` to obtain a token via OAuth.
# Create a developer app at https://app.lawmatics.com/settings/developers.
# LAWMATICS_CLIENT_ID=
# LAWMATICS_CLIENT_SECRET=
# Must EXACTLY match the callback URL registered on the developer app:
# LAWMATICS_REDIRECT_URI=http://localhost:53682/callback
