# WealthCounsel MCP — environment
# Scope is contacts + matters only (no drafting API).
# API access needs an app registered in the WC member portal (Practice Admin → Integrations).

# Option A: a bearer token directly
WEALTHCOUNSEL_ACCESS_TOKEN=

# Option B: password grant (run `npm run auth` to mint+save a token)
# WEALTHCOUNSEL_CLIENT_ID=
# WEALTHCOUNSEL_CLIENT_SECRET=
# WEALTHCOUNSEL_USERNAME=
# WEALTHCOUNSEL_PASSWORD=

# WEALTHCOUNSEL_BASE_URL=https://api.wealthcounsel.com
